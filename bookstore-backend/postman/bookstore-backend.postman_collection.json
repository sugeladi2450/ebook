{
  "info": {
    "name": "Bookstore Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/users/login"
      }
    },
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"demo_user\",\n  \"password\": \"123456\",\n  \"nickname\": \"Demo User\",\n  \"balance\": 10000\n}"
        },
        "url": "{{baseUrl}}/api/v1/users/register"
      }
    },
    {
      "name": "Get Books",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/books"
      }
    },
    {
      "name": "Get Book Detail",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/book/1"
      }
    },
    {
      "name": "Get Cart",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/cart?userId={{userId}}"
      }
    },
    {
      "name": "Add Cart Item",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{userId}},\n  \"bookId\": 2,\n  \"number\": 1\n}"
        },
        "url": "{{baseUrl}}/api/v1/cart/items"
      }
    },
    {
      "name": "Checkout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{userId}}\n}"
        },
        "url": "{{baseUrl}}/api/v1/orders"
      }
    },
    {
      "name": "Get Orders",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/v1/orders?userId={{userId}}"
      }
    }
  ]
}
